# API Testing Environment Variables
# Copy this to .env.api.local and customize for your environment

# Base URL for API testing
BASE_URL=https://opensource-demo.orangehrmlive.com
API_BASE_URL=https://jsonplaceholder.typicode.com

# OrangeHRM Demo Configuration (for examples)
ORANGEHRM_BASE_URL=https://opensource-demo.orangehrmlive.com
ORANGEHRM_LOGIN_URL=https://opensource-demo.orangehrmlive.com/web/index.php/auth/login
ORANGEHRM_USERNAME=Admin
ORANGEHRM_PASSWORD=admin123

# Authentication credentials (for testing purposes only)
API_USERNAME=Admin
API_PASSWORD=admin123
TEST_USERNAME=Admin
TEST_PASSWORD=admin123

# Test execution settings
ENABLE_API_PROJECT=true
PARALLEL_WORKERS=2
MAX_TEST_RETRIES=1

# Reporting
ALLURE_RESULTS_DIR=allure-results
PW_REPORTER_HTML=true
PW_REPORTER_JSON=true
PW_REPORTER_JUNIT=true
PW_REPORTER_ALLURE=true

# Debug settings
DEBUG_MODE=false
BROWSER_HEADLESS=true
PW_TRACE=retain-on-failure
PW_SCREENSHOT=only-on-failure
PW_VIDEO=retain-on-failure

# Timeout settings (in milliseconds)
DEFAULT_TIMEOUT=60000
ACTION_TIMEOUT=10000
NAVIGATION_TIMEOUT=30000