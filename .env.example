# Core execution
NODE_ENV=development
BASE_URL=https://opensource-demo.orangehrmlive.com/web/index.php
API_BASE_URL=https://jsonplaceholder.typicode.com
BROWSER_HEADLESS=true
PARALLEL_WORKERS=1
MAX_TEST_RETRIES=0
DEFAULT_TIMEOUT=90000
ACTION_TIMEOUT=60000
NAVIGATION_TIMEOUT=90000
PROJECT_PROFILE=examples
INCLUDE_EXAMPLES=true

# Example BDD globs
UI_BDD_FEATURES_GLOB=src/tests/UI/__examples-orangehrm__/authentication/features/**/*.feature
UI_BDD_STEPS_GLOBS=src/tests/UI/__examples-orangehrm__/authentication/step_definitions/**/*.ts,src/tests/UI/__examples-orangehrm__/common/fixtures/**/*.ts
API_BDD_FEATURES_GLOB=src/tests/API/__examples-jsonplaceholder__/users/features/**/*.feature
API_BDD_STEPS_GLOBS=src/tests/API/__examples-jsonplaceholder__/step_definitions/common-api.steps.ts,src/tests/API/__examples-jsonplaceholder__/step_definitions/data-setup.steps.ts

# Example credentials
ORANGEHRM_BASE_URL=https://opensource-demo.orangehrmlive.com/web/index.php
ORANGEHRM_LOGIN_URL=https://opensource-demo.orangehrmlive.com/web/index.php/auth/login
ORANGEHRM_USERNAME=Admin
ORANGEHRM_PASSWORD=admin123
TEST_USER_STANDARD_EMAIL=
TEST_USER_STANDARD_USERNAME=
TEST_USER_STANDARD_PASSWORD=
TEST_USER_ADMIN_EMAIL=
TEST_USER_ADMIN_USERNAME=
TEST_USER_ADMIN_PASSWORD=

# Azure Key Vault integration (optional)
AZURE_KEY_VAULT_URL=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
